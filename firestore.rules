rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@oncosoft[.]io$');
    }

    // 프로젝트 문서 자체에 대한 멤버십 검사 — resource.data 직접 참조 (query에 효율적)
    function isProjectMember() {
      return request.auth.uid in resource.data.members;
    }
    // 서브컬렉션(reviews)에서 부모 프로젝트 멤버십 검사 — get() 필요
    function isParentProjectMember(projectId) {
      return request.auth.uid in
        get(/databases/$(database)/documents/projects/$(projectId)).data.members;
    }

    function willBeMember() {
      return request.auth.uid in request.resource.data.members;
    }

    // Workspace 전체 공유: @oncosoft.io 인증된 모든 사용자가 모든 모델 read 가능.
    // Write는 여전히 owner / member / self-review만 (config 보호 + review 격리).
    match /projects/{projectId} {
      allow read:   if isAuthed();
      allow create: if isAuthed()
                    && willBeMember()
                    && request.resource.data.owner == request.auth.uid;
      // 어느 인증 유저든 자기 자신을 members에 추가 가능 (self-join 자동화).
      // 기존 member는 자유롭게 config 수정. owner 변경은 불가.
      allow update: if isAuthed() && (
        (isProjectMember()
          && request.resource.data.owner == resource.data.owner)
        ||
        (!(request.auth.uid in resource.data.members)
          && request.auth.uid in request.resource.data.members
          && request.resource.data.owner == resource.data.owner
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'updatedAt']))
      );
      allow delete: if isAuthed() && resource.data.owner == request.auth.uid;

      match /reviews/{reviewerUid} {
        allow read:  if isAuthed();
        allow write: if isAuthed() && request.auth.uid == reviewerUid;
      }
    }

    match /userProjects/{uid} {
      allow read, write: if isAuthed() && request.auth.uid == uid;
    }

    // Legacy 평가 데이터 — 이전 도구가 저장한 컬렉션. 읽기 전용으로 노출.
    match /evaluations/{evalId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // Audit trail — critical actions 추적 (create/delete/join). append-only, 본인 이벤트만 read.
    match /audit/{eventId} {
      allow create: if isAuthed()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.timestamp == request.time;
      allow read: if isAuthed() && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
