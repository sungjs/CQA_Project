{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "CLAUDE.md",
      "CQA_Input_Tool_GTV_Extension_Spec.md",
      "DESIGN_CHANGES.md",
      "script_test.js",
      "prev_eval/**",
      "tools/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|html|css)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
